{
    "name": "RADARLIB Development Container",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "../.."
    },
    "mounts": [
        "source=${localWorkspaceFolder}/outputs,target=/workspaces/radarlib/outputs,type=bind"
    ],
    "containerEnv": {
        "PYTHONUNBUFFERED": "1",
        "FTP_HOST": "200.16.116.24",
        "FTP_USER": "IMontamat",
        "FTP_PASS": "1m0nt",
        "ROOT_CACHE_PATH": "/workspaces/radarlib/cache",
        "ROOT_RADAR_FILES_PATH": "/workspaces/radarlib/data/radares",
        "ROOT_RADAR_PRODUCTS_PATH": "/workspaces/radarlib/product_output"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.pythonPath": "/usr/local/bin/python",
                "python.linting.enabled": true,
                "python.linting.pylintEnabled": true,
                "python.testing.pytestEnabled": true,
                "python.testing.unittestEnabled": false
            },
            "extensions": [
                "ms-python.python",
                "qwtel.sqlite-viewer"
            ]
        }
    },
    "postCreateCommand": ".devcontainer/radarlib/post-create.sh",
    "remoteUser": "root"
}
